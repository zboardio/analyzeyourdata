# ================================
# APPLICATION SETTINGS
# ================================
APP_LANGUAGE=en

# ================================
# SERVER CONFIGURATION
# ================================
APP_HOST=0.0.0.0
APP_PORT=8050
APP_DEBUG=True

# ================================
# FILE UPLOAD SETTINGS
# ================================
MAX_FILE_SIZE_MB=20
SUPPORTED_FILE_FORMATS=csv,xlsx,xls,json,parquet,h5,hdf5,h6,plh,txt,log,db,sqlite,sqlite3

# ================================
# CONTENT DIRECTORIES
# ================================
MARKDOWN_DIRECTORY=assets/markdown
ASSETS_DIRECTORY=assets

# ================================
# UI ASSETS
# ================================
# Logo in navbar (leave empty to hide logo, brand text remains)
LOGO_PATH=/assets/image/logo.png
# Favicon: Dash auto-discovers /assets/favicon.ico — no config needed

# ================================
# EXTERNAL LINKS
# ================================
GITHUB_URL=https://github.com/your-repo
WEBSITE_URL=https://example.com/en/
CONTACT_EMAIL=contact@example.com
# Documentation URL (leave empty to hide docs buttons in footer and modal)
DOCUMENTATION_URL=

# Donation / Support link (Stripe, Buy Me a Coffee, etc.)
# Leave empty to hide the donation card
DONATE_URL=

# YouTube intro video (embed URL, not watch URL)
# Use format: https://www.youtube.com/embed/VIDEO_ID
# Leave empty to hide the video section
YOUTUBE_INTRO_URL=

# ================================
# COMPANY / BRANDING
# ================================
COMPANY_NAME=Your Company Name

# ================================
# AG GRID CONFIGURATION
# ================================
AG_GRID_LICENSE_KEY=your-ag-grid-license-key
AG_GRID_THEME=ag-theme-alpine
AG_GRID_HEIGHT=700

# ================================
# CHART SETTINGS
# ================================
DEFAULT_CHART_TYPE=scatter
CHART_HEIGHT=700
CHART_COLOR_SCHEME=plotly

# ================================
# LANGUAGE SETTINGS
# ================================
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,cs,da,de,es,fr,hr,it,nl,pl,pt,sk,sl,sv,uk

# Language instance URLs (for navbar cross-links)
# Local development defaults:
APP_URL_EN=http://localhost:8050
APP_URL_CS=http://localhost:8051
APP_URL_DE=http://localhost:8052
APP_URL_PL=http://localhost:8053
APP_URL_DA=http://localhost:8054
APP_URL_ES=http://localhost:8055
APP_URL_FR=http://localhost:8056
APP_URL_HR=http://localhost:8057
APP_URL_IT=http://localhost:8058
APP_URL_NL=http://localhost:8059
APP_URL_PT=http://localhost:8060
APP_URL_SK=http://localhost:8061
APP_URL_SL=http://localhost:8062
APP_URL_SV=http://localhost:8063
APP_URL_UK=http://localhost:8064

# Production example (Cloudflare Tunnel subdomains):
# APP_URL_EN=https://en.example.com
# APP_URL_CS=https://cs.example.com
# APP_URL_DA=https://da.example.com
# APP_URL_DE=https://de.example.com
# APP_URL_ES=https://es.example.com
# APP_URL_FR=https://fr.example.com
# APP_URL_HR=https://hr.example.com
# APP_URL_IT=https://it.example.com
# APP_URL_NL=https://nl.example.com
# APP_URL_PL=https://pl.example.com
# APP_URL_PT=https://pt.example.com
# APP_URL_SK=https://sk.example.com
# APP_URL_SL=https://sl.example.com
# APP_URL_SV=https://sv.example.com
# APP_URL_UK=https://uk.example.com

# ================================
# DATABASE SETTINGS (MongoDB)
# ================================
MONGO_URI=mongodb+srv://user:password@cluster.example.net/
MONGODB_DATABASE=analyzeYourData
MONGODB_COLLECTION_LOGS=usageLogs
MONGODB_COLLECTION_FEEDBACK=feedback

# ================================
# PERFORMANCE MONITORING
# ================================
MEMORY_MONITORING_ENABLED=True
MEMORY_MONITORING_INTERVAL=3

# ================================
# SECURITY
# ================================
SECRET_KEY=change-this-to-a-random-secret-in-production
